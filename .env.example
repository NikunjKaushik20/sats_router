# ── OpenAI (Sponsor) ───────────────────────────────────────────────────
OPENAI_API_KEY=

# ── MoneyDevKit (MDK) ──────────────────────────────────────────────────
# Get from: https://moneydevkit.com or run `npx @moneydevkit/create`
MDK_ACCESS_TOKEN=
MDK_MNEMONIC=
MDK_WEBHOOK_SECRET=

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Agent Wallet (optional) ────────────────────────────────────────────
AGENT_WALLET_URL=http://localhost:3456

# ── Provider Payout Lightning Addresses (optional) ─────────────────────
# When set, SatsRouter will route the provider's share of every L402 payment
# (priceSats - 10% fee) to these LUD-16 Lightning Addresses via real Lightning.
# Leave blank to record amounts as "owed" without paying. Useful for forks.
PAYOUT_QUICK_SCANNER=
PAYOUT_DEEP_DIAGNOSER=
PAYOUT_STORYTELLER=
PAYOUT_HUMAN_VERIFIER=
