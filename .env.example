# ── OpenAI (Sponsor) ───────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Sarvam AI (OpenAI-compatible chat API) ─────────────────────────────
SARVAM_API_KEY=

# ── Local LLM (Ollama / vLLM OpenAI-compatible server) ───────────────────
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b

# ── Groq (OpenAI-compatible, free tier) ────────────────────────────────
GROQ_API_KEY=
# Optional override — default llama-3.3-70b-versatile
GROQ_MODEL=

# ── Together.ai (OpenAI-compatible) ────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_MODEL=

# ── MoneyDevKit (MDK) ──────────────────────────────────────────────────
# Get from: https://moneydevkit.com or run `npx @moneydevkit/create`
MDK_ACCESS_TOKEN=
MDK_MNEMONIC=
MDK_WEBHOOK_SECRET=

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Agent Wallet (optional) ────────────────────────────────────────────
AGENT_WALLET_URL=http://localhost:3456

# ── Provider Payout Lightning Addresses (optional) ─────────────────────
# When set, SatsRouter will route the provider's share of every L402 payment
# (priceSats - 10% fee) to these LUD-16 Lightning Addresses via real Lightning.
# Leave blank to record amounts as "owed" without paying. Useful for forks.
PAYOUT_QUICK_SCANNER=
PAYOUT_DEEP_DIAGNOSER=
PAYOUT_STORYTELLER=
PAYOUT_HUMAN_VERIFIER=
